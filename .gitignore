# Python/cache
__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
coverage.xml
htmlcov/
build/
dist/
*.egg-info/

# Local environments and secrets
.env
*.env
uv.lock
venv/
venv_test/
.venv/
.DS_Store
.vscode/

# Generated artifacts
artifacts/
plots/
logs/
*.log
*.pt
*.pth
*.pkl
