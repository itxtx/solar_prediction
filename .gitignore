# Full/local datasets stay out of Git. The curated sample dataset is tracked.
*.csv
!data/
!data/sample/
!data/sample/*.csv

# README/report images are allowed, ad-hoc generated images are ignored elsewhere.
*.png
!assets/
!assets/images/
!assets/images/*.png

# Notebook checkpoints
.ipynb_checkpoints/
